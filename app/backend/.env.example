FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

AUTH_COOKIE_NAME=nsql_auth
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_SECONDS=3600

CORS_ALLOWED_ORIGINS=https://naturalsql.online,http://localhost:5173,http://127.0.0.1:5173

LOGIN_RATE_LIMIT=5/minute
CHAT_RATE_LIMIT=5/minute

DB_URL_SPECT=postgresql://user:password@localhost:5432/dbname
GEMINI_API_KEY=
OPENROUTER_API_KEY=
